[Unit]
Description=Chemist Agent API Gateway
After=network.target

[Service]
Type=simple
User=root
WorkingDirectory=/opt/projects/chemist-agent
EnvironmentFile=/opt/projects/chemist-agent/.env
ExecStart=/opt/projects/chemist-agent/venv/bin/uvicorn real_proj.mvp.api:app --host 0.0.0.0 --port 8765
Restart=always
RestartSec=5
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
